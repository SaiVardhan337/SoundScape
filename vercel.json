{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/css/(.*)",
      "destination": "/static/css/$1"
    },
    {
      "source": "/js/(.*)",
      "destination": "/static/js/$1"
    },
    {
      "source": "/audio/(.*)",
      "destination": "/static/audio/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/static/index.html"
    }
  ]
}
