{
  "version": 2,
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "main.py"
    },
    {
      "src": "/css/(.*)",
      "dest": "static/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "static/js/$1"
    },
    {
      "src": "/audio/(.*)",
      "dest": "static/audio/$1"
    },
    {
      "src": "/(.*)",
      "dest": "static/index.html"
    }
  ]
}
